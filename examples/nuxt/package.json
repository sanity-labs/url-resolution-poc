{
  "name": "example-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "pnpm --filter @sanity/routes build && nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typegen": "cd ../../studio && pnpx sanity schema extract --enforce-required-fields && pnpx sanity typegen generate"
  },
  "dependencies": {
    "@nuxtjs/sanity": "^2.2.0",
    "@portabletext/vue": "^1.0.14",
    "@sanity/routes": "workspace:*",
    "nuxt": "^4.3.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
