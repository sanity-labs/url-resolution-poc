{
  "name": "example-react-router",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "pnpm --filter @sanity/routes build && react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typegen": "cd ../../studio && pnpx sanity schema extract --enforce-required-fields && pnpx sanity typegen generate"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity/client": "^7.16.0",
    "@sanity/routes": "workspace:*",
    "groq": "^3.99.0",
    "isbot": "^5.1.35",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
