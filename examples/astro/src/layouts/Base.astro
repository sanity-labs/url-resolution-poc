---
interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — URL Resolution POC</title>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
