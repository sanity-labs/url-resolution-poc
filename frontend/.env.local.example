# Copy this to .env.local

# Sanity API read token — needed for visual editing (draft mode) and defineLive
# Route resolution does NOT need a token (public IDs)
SANITY_API_READ_TOKEN=your-read-token-here

# Route environment (matches baseUrls[].name in route config)
SANITY_ROUTES_ENV=production

# Visual editing
NEXT_PUBLIC_SANITY_PROJECT_ID=bb8k7pej
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
