{
  "name": "@sanity/routes",
  "version": "0.0.1",
  "description": "URL route resolution for Sanity",
  "main": "dist/resolver-entry.js",
  "types": "dist/resolver-entry.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/resolver-entry.d.ts",
      "default": "./dist/resolver-entry.js"
    },
    "./resolver": {
      "types": "./dist/resolver-entry.d.ts",
      "default": "./dist/resolver-entry.js"
    },
    "./studio": {
      "types": "./dist/studio-entry.d.ts",
      "default": "./dist/studio-entry.js"
    },
    "./handler": {
      "types": "./dist/handler-entry.d.ts",
      "default": "./dist/handler-entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@sanity/client": "^6.0.0 || ^7.0.0",
    "@sanity/functions": "^1.0.0",
    "@sanity/icons": "^3.0.0",
    "@sanity/ui": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "rxjs": "^7.0.0",
    "sanity": "^3.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@sanity/functions": {
      "optional": true
    },
    "sanity": {
      "optional": true
    },
    "@sanity/icons": {
      "optional": true
    },
    "@sanity/ui": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sanity/client": "^7.0.0",
    "@sanity/functions": "^1.2.0",
    "@sanity/icons": "^3.0.0",
    "@sanity/ui": "^2.0.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "react": "^19.0.0",
    "rxjs": "^7.0.0",
    "sanity": "^5.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "dependencies": {
    "@sanity/id-utils": "^1.0.0"
  }
