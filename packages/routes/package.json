{
  "name": "@sanity/routes",
  "version": "0.0.1",
  "description": "URL route resolution for Sanity",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "default": "./dist/resolver.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "default": "./dist/build.js"
    },
    "./blueprint": {
      "types": "./dist/blueprint.d.ts",
      "default": "./dist/blueprint.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "@sanity/client": "^6.0.0 || ^7.0.0",
    "@sanity/icons": "^3.0.0",
    "@sanity/ui": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "sanity": "^3.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "sanity": {
      "optional": true
    },
    "@sanity/icons": {
      "optional": true
    },
    "@sanity/ui": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sanity/client": "^7.0.0",
    "@sanity/icons": "^3.0.0",
    "@sanity/ui": "^2.0.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "react": "^19.0.0",
    "sanity": "^5.0.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
